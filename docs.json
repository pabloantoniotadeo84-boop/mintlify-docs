{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Vane",
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg"
  },
  "favicon": "/favicon.svg",
  "appearance": {
    "default": "dark"
  },
  "colors": {
    "primary": "#b5451b",
    "light": "#c8552a",
    "dark": "#9a3510",
    "background": {
      "dark": "#0a1628",
      "light": "#f5f0e8"
    }
  },
  "fonts": {
    "heading": {
      "family": "Bricolage Grotesque",
      "source": "google"
    },
    "body": {
      "family": "Bricolage Grotesque",
      "source": "google"
    }
  },
  "css": ["/styles/custom.css"],
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/vane-build/vane"
      }
    ],
    "primary": {
      "label": "Request Access",
      "href": "https://vane.build/#contact"
    }
  },
  "navigation": {
    "pages": [
      {
        "group": "Getting Started",
        "pages": [
          "introduction",
          "quickstart",
          "concepts"
        ]
      },
      {
        "group": "API Reference",
        "pages": [
          "api-reference/authentication",
          "api-reference/rate-limits",
          "api-reference/health",
          "api-reference/companies",
          "api-reference/keys",
          "api-reference/oauth",
          "api-reference/agents",
          "api-reference/passports",
          "api-reference/revocation",
          "api-reference/ocsp",
          "api-reference/attestation",
          "api-reference/chain",
          "api-reference/delegation",
          "api-reference/ca",
          "api-reference/websocket"
        ]
      },
      {
        "group": "SDK & Integrations",
        "pages": [
          "sdk/typescript-sdk",
          "sdk/mcp-middleware",
          "sdk/langchain",
          "sdk/crewai",
          "sdk/openai-agents",
          "sdk/sidecar"
        ]
      },
      {
        "group": "Security",
        "pages": [
          "security/ed25519",
          "security/merkle-tree",
          "security/passport-format",
          "security/delegation-chains",
          "security/envelope-encryption",
          "security/revocation",
          "security/mtls"
        ]
      },
      {
        "group": "Deployment",
        "pages": [
          "deployment/environment-variables",
          "deployment/postgresql",
          "deployment/railway",
          "deployment/sentry"
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/vane-build/vane"
    }
  }
}
